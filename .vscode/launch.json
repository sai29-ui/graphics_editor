{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Graphics Editor (CLI Mode - Integrated)",
            "type": "cppdbg",
            "request": "launch",
            "program": "C:\\msys64\\ucrt64\\bin\\editor.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:\\msys64\\ucrt64\\bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build 2D Graphics Editor"
        },
        {
            "name": "Run Graphics Editor (TUI Mode - External)",
            "type": "cppdbg",
            "request": "launch",
            "program": "C:\\msys64\\ucrt64\\bin\\editor.exe",
            "args": ["--tui"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:\\msys64\\ucrt64\\bin;${env:PATH}"
                }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build 2D Graphics Editor"
        }
    ]
}
